# Subreddit to track (no r/ prefix)
REDDIT_SUBREDDIT=WorldOfWarships

# Storage (Hetzner volume)
REDDIT_DB_PATH=/mnt/HC_Volume_105012469/reddit.db

# Dashboard API
REDDIT_DASHBOARD_PORT=3002
REDDIT_DASHBOARD_SECRET=pick_a_strong_secret_here

# Collection intervals (minutes)
POST_POLL_INTERVAL_MIN=15
STATS_POLL_INTERVAL_MIN=60

# OpenAI (for sentiment analysis and chat)
OPENAI_API_KEY=sk-...

# Hour (UTC) to run daily sentiment analysis (default: 8 = 8am UTC)
SENTIMENT_HOUR=8
